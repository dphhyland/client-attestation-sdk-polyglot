{
  "name": "@dphhyland/client-attestation-sdk",
  "version": "0.1.0",
  "description": "Client-side builder SDK for OAuth Attestation-Based Client Authentication",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./validator": {
      "types": "./dist/validator/index.d.ts",
      "import": "./dist/validator/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "emit": "tsx emit.ts",
    "validate-emit": "tsx validate-emit.ts"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dphhyland/client-attestation-sdk-polyglot.git",
    "directory": "typescript"
  },
  "homepage": "https://github.com/dphhyland/client-attestation-sdk-polyglot/tree/main/typescript",
  "dependencies": {
    "jose": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
